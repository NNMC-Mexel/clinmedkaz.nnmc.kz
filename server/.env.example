HOST=0.0.0.0
PORT=1337

# Generate long random values before production deployment.
APP_KEYS=change-me-1,change-me-2,change-me-3,change-me-4
API_TOKEN_SALT=change-me-api-token-salt
ADMIN_JWT_SECRET=change-me-admin-jwt-secret
TRANSFER_TOKEN_SALT=change-me-transfer-token-salt
ENCRYPTION_KEY=change-me-encryption-key
JWT_SECRET=change-me-jwt-secret

# Optional service token for protected maintenance endpoints.
PAYMENT_SERVICE_TOKEN=change-me-service-token

# Local default. Use postgres in production.
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# PostgreSQL production example.
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:password@localhost:5432/clinmedkaz_cms
# DATABASE_SSL=false
