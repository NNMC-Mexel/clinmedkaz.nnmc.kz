NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Change this before putting the admin panel online.
ADMIN_TOKEN=change-me-long-random-token
ADMIN_EMAIL=admin@clinmedkaz.org

# Publication fee. Residents of Kazakhstan pay the KZT equivalent;
# non-residents pay the USD amount if the Halyk terminal supports USD.
PUBLICATION_FEE_USD=300
USD_TO_KZT_RATE=485.4
PUBLICATION_FEE_DISPLAY=300 USD

# Halyk ePay test credentials from https://epayment.kz/ru/docs/Test-credentials
HALYK_ENV=test
HALYK_CLIENT_ID=test
HALYK_CLIENT_SECRET=yF587AV9Ms94qN2QShFzVR3vFnWkhjbAK3sG
HALYK_TERMINAL_ID=67e34d63-102f-4bd1-898e-370781d0074d

# Optional SMTP. If missing, emails are printed to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ClinMedKaz payments <no-reply@clinmedkaz.org>"

# Legal/business details required by Halyk review.
BUSINESS_NAME="АО «Национальный научный медицинский центр»"
BUSINESS_COUNTRY="Kazakhstan"
