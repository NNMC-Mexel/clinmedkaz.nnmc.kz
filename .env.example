NODE_ENV=development
PORT=1337
BASE_URL=http://localhost:5173

# Required. The app refuses to boot in production if these are missing or use
# the insecure "change-me-*" placeholders. Generate strong values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-long-random-token
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
# Extra admin accounts (optional): "user2:pass2,user3:pass3".
# Username is everything before the first ":"; password the rest (may contain
# ":" but not ","). Each must be a strong password in production.
ADMIN_USERS=
ADMIN_SESSION_SECRET=change-me-session-secret
ADMIN_SESSION_TTL_HOURS=12
ADMIN_EMAIL=Nnmc.marketing@gmail.com

# Backend is Strapi in ./server. Client talks to it through REST /api/*.
STRAPI_URL=http://localhost:1337

# Publication fee. Residents of Kazakhstan pay the KZT equivalent;
# non-residents pay the USD amount if the Halyk terminal supports USD.
PUBLICATION_FEE_USD=300
USD_TO_KZT_RATE=485.4
PUBLICATION_FEE_DISPLAY=300 USD

# Halyk ePay credentials. Fill with test credentials locally, and replace ALL
# values with production credentials before going live. Never commit real secrets.
HALYK_ENV=test
HALYK_CLIENT_ID=change-me-halyk-client-id
HALYK_CLIENT_SECRET=change-me-halyk-client-secret
HALYK_TERMINAL_ID=change-me-halyk-terminal-id
# Shared secret appended to the postlink callback URL so only Halyk can reach it.
# Required in production. Generate a random value like the admin secrets above.
HALYK_POSTLINK_SECRET=change-me-postlink-secret

# Optional SMTP. If missing, emails are printed to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="ClinMedKaz payments <no-reply@clinmedkaz.org>"

# Legal/business details required by Halyk review.
BUSINESS_NAME="АО «Национальный научный медицинский центр»"
BUSINESS_COUNTRY="Kazakhstan"
BUSINESS_CITY="Astana"
BUSINESS_LEGAL_ADDRESS="пр. Абылай хана, 42"
BUSINESS_ACTUAL_ADDRESS="пр. Абылай хана, 42"
BUSINESS_BIN="000640000596"
BUSINESS_KBE=16
BUSINESS_WORK_HOURS="Mon-Fri 09:00-18:00"
SUPPORT_PHONE="+7 (7172) 57-74-40"
SUPPORT_EMAIL=Nnmc.marketing@gmail.com
CHAIRMAN_NAME="Байгенжин Абай Кабатаевич"

BANK_NAME="АО «Народный банк»"
BANK_BIK=HSBKKZKX
BANK_KBE=14
BANK_IBAN=KZ806017111000000485
